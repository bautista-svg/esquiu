---
import { Image } from "astro:assets";
import BrandStripes from "./BrandStripes.astro";
import escudo from "../assets/img/escudo.png";
import { SITE } from "../data/site";
import Icon from "./Icon.astro";

const year = new Date().getFullYear();

const columns = [
  {
    title: "Institución",
    links: [
      { label: "Historia y misión", href: "/#esencia" },
      { label: "Comisión Directiva", href: "/equipo#comision-directiva" },
      { label: "Nuestro equipo", href: "/equipo" },
      { label: "Exalumnos", href: "/exalumnos" },
    ],
  },
  {
    title: "Propuesta",
    links: [
      { label: "Proyecto educativo", href: "/proyecto-educativo" },
      { label: "Nivel Inicial", href: "/proyecto-educativo#inicial" },
      { label: "Nivel Primario", href: "/proyecto-educativo#primaria" },
      { label: "Nivel Secundario", href: "/proyecto-educativo#secundaria" },
      { label: "Áreas transversales", href: "/areas" },
    ],
  },
  {
    title: "Familias",
    links: [
      { label: "Admisiones 2026", href: "/admisiones" },
      { label: "Servicios y portales", href: "/servicios" },
      { label: "Contacto", href: "/contacto" },
    ],
  },
];
---

<footer class="bg-night text-paper">
  <BrandStripes />

  <div
    class="container-site grid gap-12 py-16 md:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr] lg:gap-8 lg:py-20"
  >
    <div class="max-w-sm">
      <a href="/" class="inline-flex items-center gap-3" aria-label="Colegio Esquiú — Inicio">
        <Image src={escudo} alt="" width={96} height={101} densities={[1, 2]} class="h-12 w-auto" />
        <span class="flex flex-col leading-none">
          <span class="font-display text-lg font-semibold tracking-tight">Colegio Esquiú</span>
          <span class="overline-label text-paper/50 mt-1.5 text-[0.6rem]"
            >Veritas · desde {SITE.founded}</span
          >
        </span>
      </a>
      <p class="text-paper/65 mt-6 text-[0.95rem] leading-relaxed">
        Asociación civil sin fines de lucro conducida por sus familias. Educación católica bilingüe
        en Belgrano, desde el nivel inicial hasta el secundario.
      </p>
      <ul class="text-paper/75 mt-7 space-y-3 text-[0.95rem]">
        <li>
          <a
            href={SITE.mapsUrl}
            target="_blank"
            rel="noreferrer"
            class="group hover:text-paper inline-flex items-start gap-2.5"
          >
            <Icon name="pin" size={17} class="text-rose mt-1 shrink-0" />
            <span>{SITE.address.street}, {SITE.address.neighborhood} · {SITE.address.city}</span>
          </a>
        </li>
        <li>
          <a
            href={`mailto:${SITE.email}`}
            class="hover:text-paper inline-flex items-center gap-2.5"
          >
            <Icon name="mail" size={17} class="text-rose shrink-0" />
            <span>{SITE.email}</span>
          </a>
        </li>
        <li>
          <a href={SITE.phoneHref} class="hover:text-paper inline-flex items-center gap-2.5">
            <Icon name="phone" size={17} class="text-rose shrink-0" />
            <span>{SITE.phone}</span>
          </a>
        </li>
      </ul>
    </div>

    {
      columns.map((column) => (
        <nav aria-label={column.title}>
          <p class="overline-label text-paper/45">{column.title}</p>
          <ul class="mt-5 space-y-3">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-paper/75 hover:text-paper text-[0.95rem] transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }
  </div>

  <div class="border-paper/10 border-t">
    <div
      class="container-site text-paper/50 flex flex-col items-start justify-between gap-4 py-7 text-[0.85rem] sm:flex-row sm:items-center"
    >
      <p>© {year} Colegio Esquiú · Asociación civil sin fines de lucro</p>
      <a
        href={SITE.instagram}
        target="_blank"
        rel="noreferrer"
        class="hover:text-paper inline-flex items-center gap-2 transition-colors"
      >
        <Icon name="instagram" size={16} />
        <span>@colegioesquiu</span>
      </a>
    </div>
  </div>
</footer>
