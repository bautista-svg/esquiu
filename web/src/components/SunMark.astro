---
/**
 * Sol de dieciséis rayos inspirado en el "Veritas" del escudo institucional.
 * Se usa como marca decorativa; siempre acompañado de aria-hidden.
 */
interface Props {
  size?: number;
  class?: string;
}

const { size = 20, class: className } = Astro.props;
const rays = Array.from({ length: 16 }, (_, i) => (i * 360) / 16);
---

<svg
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  aria-hidden="true"
  class={className}
>
  <circle cx="24" cy="24" r="9.5" fill="currentColor"></circle>
  {
    rays.map((angle) => (
      <line
        x1="24"
        y1="10.5"
        x2="24"
        y2={angle % 45 === 0 ? "2.5" : "5.5"}
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"
        transform={`rotate(${angle} 24 24)`}
      />
    ))
  }
</svg>
