---
/**
 * Hero cinematográfico de páginas interiores: foto full-bleed + tipografía clara,
 * misma familia visual que el home, cerrado con las tres franjas.
 */
import type { ImageMetadata } from "astro";
import { Picture } from "astro:assets";
import BrandStripes from "./BrandStripes.astro";

interface Props {
  overline: string;
  title: string;
  lead?: string;
  image: ImageMetadata;
  imageAlt?: string;
  imagePosition?: string;
}

const { overline, title, lead, image, imageAlt = "", imagePosition = "center" } = Astro.props;
---

<section class="page-hero relative flex min-h-[68svh] items-end overflow-clip md:min-h-[72svh]">
  <div class="absolute inset-0">
    <Picture
      src={image}
      formats={["avif", "webp"]}
      widths={[768, 1280, 1920, 2560]}
      sizes="100vw"
      alt={imageAlt}
      class="hero-zoom absolute inset-0 h-full w-full object-cover"
      style={`object-position: ${imagePosition}`}
      loading="eager"
      fetchpriority="high"
    />
    <div
      class="from-night/70 via-night/25 pointer-events-none absolute inset-x-0 top-0 h-40 bg-gradient-to-b to-transparent"
      aria-hidden="true"
    >
    </div>
    <div
      class="from-night/92 via-night/45 pointer-events-none absolute inset-0 bg-gradient-to-t to-transparent"
      aria-hidden="true"
    >
    </div>
  </div>

  <div class="container-site relative w-full pt-[9rem] pb-12 md:pb-14">
    <p class="overline-label hero-fade text-rose flex items-center gap-2" style="--d:60ms">
      {overline}
    </p>
    <h1 class="text-display text-paper hero-fade mt-4 max-w-4xl" style="--d:140ms">{title}</h1>
    {
      lead && (
        <p class="text-lead hero-fade text-paper/80 mt-5 max-w-2xl" style="--d:230ms">
          {lead}
        </p>
      )
    }
    <div class="hero-fade page-hero-slot mt-8" style="--d:320ms">
      <slot />
    </div>
  </div>
</section>
<BrandStripes />

<style>
  .page-hero-slot :global(.chip) {
    border-color: rgb(250 248 244 / 0.28);
    background: rgb(250 248 244 / 0.1);
    color: var(--color-paper);
  }
  .page-hero-slot :global(.chip:hover) {
    border-color: rgb(250 248 244 / 0.5);
    background: rgb(250 248 244 / 0.18);
  }
</style>
