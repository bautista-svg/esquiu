---
import { Picture } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBand from "../components/CtaBand.astro";

import inicialPatio from "../assets/img/inicial-patio.jpg";
import portonHierro from "../assets/img/porton-hierro.jpg";
import salaRompecabezas from "../assets/img/sala-rompecabezas.jpg";

const levels = [
  {
    id: "inicial",
    index: "01",
    name: "Nivel Inicial",
    ages: "Salas de 2 a 5 años",
    headline: { lines: ["El juego no es", "un recreo:"], accent: "es el método." },
    lead: "El juego integra todos los contenidos: lo matemático, lo lingüístico, las ciencias, la música y la fe.",
    image: salaRompecabezas,
    imageAlt: "Tres nenes de la sala armando un rompecabezas en una mesa naranja",
    imagePosition: "center 35%",
    points: [
      {
        title: "Inglés desde el primer día",
        text: "Maestras bilingües integran el idioma con libros, canciones, arts & crafts y dramatizaciones.",
      },
      {
        title: "Fe en familia",
        text: "Cada sala celebra su fiesta anual: Bendición de las Familias, Fiesta de la Vida, Peregrinación de la Virgen.",
      },
      {
        title: "Cuerpo y juego",
        text: "Educación física y musical desde sala de 2, Día de la Naturaleza y Día del Deporte en Familia.",
      },
    ],
    metaTitle: "Jornadas",
    meta: [
      "Sala de 2 — simple, turno mañana",
      "Sala de 3 — simple, opción de extender",
      "Salas de 4 y 5 — doble obligatoria",
      "Mañana 8:20–11:50 · tarde 13:00–16:30",
    ],
  },
  {
    id: "primaria",
    index: "02",
    name: "Nivel Primario",
    ages: "1.º a 7.º grado · 8:00 a 16:30",
    headline: { lines: ["Cuerpo, mente", "y amigos:"], accent: "crecen juntos." },
    lead: "Doble jornada con inglés intensivo tres tardes por semana y deporte en Garín las restantes.",
    image: inicialPatio,
    imageAlt: "Alumnas de primaria formadas en el patio durante una celebración",
    imagePosition: "center 30%",
    points: [
      {
        title: "Semana de la Literatura",
        text: "Feria del libro, autores y narradores de la propia comunidad.",
      },
      {
        title: "Proyecto MINU",
        text: "Asamblea tipo ONU: investigan un país y un tópico como delegados.",
      },
      {
        title: "Olimpíadas y Cartelera",
        text: "Desafíos matemáticos y proyectos frente a toda la comunidad.",
      },
      {
        title: "Juegoteca y Digital House",
        text: "Juegos en el recreo del mediodía y programación web con certificación.",
      },
    ],
    metaTitle: "Talleres",
    meta: [
      "Arte y tecnología",
      "Ciencias y método científico",
      "Teatro y juegos teatrales",
      "Banda y orquesta",
      "Aerofósforomodelismo (7.º)",
    ],
  },
  {
    id: "secundaria",
    index: "03",
    name: "Nivel Secundario",
    ages: "1.º a 5.º año · tres orientaciones",
    headline: { lines: ["Egresan bilingües,", "con valores"], accent: "y con rumbo." },
    lead: "Carga ampliada en inglés, catequesis, educación física, arte y tutoría — con certificación bilingüe de Cambridge.",
    image: portonHierro,
    imageAlt: "El portón de hierro del colegio, con el escudo Veritas y la casona de fondo",
    imagePosition: "center 40%",
    points: [
      {
        title: "Más allá del aula",
        text: "Olimpíadas, Modelo de ONU, campamentos, viajes de estudio y microemprendimientos.",
      },
      {
        title: "Hacia la universidad",
        text: "Orientación vocacional, ACAP y convenios con UCA, Di Tella, UdeSA, ITBA, Austral y más.",
      },
      {
        title: "Tutoría continua",
        text: "Acompañamiento personalizado a lo largo de los cinco años.",
      },
    ],
    metaTitle: "Orientaciones",
    meta: [
      "01 · Ciencias Sociales y Humanidades",
      "02 · Ciencias Naturales",
      "03 · Economía y Administración",
    ],
  },
] as const;
---

<BaseLayout
  title="Proyecto educativo · Inicial, Primaria y Secundaria | Colegio Esquiú"
  description="Un recorrido de los 2 a los 18 años: nivel inicial con eje lúdico, primaria de doble jornada con inglés intensivo y secundaria con tres orientaciones y exámenes de Cambridge."
  headerTone="dark"
>
  <h1 class="sr-only">Proyecto educativo del Colegio Esquiú</h1>

  <!-- Sin hero: quien llegó acá ya sabe dónde está. Directo al recorrido:
       scroll vertical → viaje lateral, con toda la info de cada nivel. -->
  <section class="pano-wrap" data-pano aria-label="Los tres niveles, en un recorrido">
    <div class="pano-sticky">
      <div class="pano-track" data-pano-track>
        {
          levels.map((level) => (
            <article class="pano-panel" id={level.id}>
              <Picture
                src={level.image}
                formats={["avif", "webp"]}
                widths={[768, 1280, 1920]}
                sizes="100vw"
                alt={level.imageAlt}
                class="pano-bg"
                style={`object-position: ${level.imagePosition}`}
                loading="lazy"
                decoding="async"
              />
              <div class="pano-scrim" aria-hidden="true"></div>

              <div class="pano-content container-site" data-pano-copy>
                <header class="pano-head">
                  <span class="pano-num" aria-hidden="true">{level.index}</span>
                  <p class="overline-label text-rose">
                    {level.name} · {level.ages}
                  </p>
                  <h2 class="pano-title">
                    {level.headline.lines.map((line) => <span class="block">{line}</span>)}
                    <span class="is-accent block">{level.headline.accent}</span>
                  </h2>
                  <p class="pano-lead">{level.lead}</p>
                </header>

                <div class="pano-info">
                  <ul class="pano-points">
                    {level.points.map((point) => (
                      <li>
                        <h3>{point.title}</h3>
                        <p>{point.text}</p>
                      </li>
                    ))}
                  </ul>
                  <div class="pano-meta">
                    <p class="overline-label">{level.metaTitle}</p>
                    <ul>
                      {level.meta.map((item) => (
                        <li>
                          <span class="pano-dot" aria-hidden="true" />
                          {item}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <div class="pano-progress" aria-hidden="true">
        <div class="pano-bar">
          <span class="pano-fill" data-pano-fill></span>
        </div>
        <ul class="pano-labels">
          {levels.map((level) => <li data-pano-label>{level.name.replace("Nivel ", "")}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <CtaBand
    title="¿Querés verlo en persona?"
    lead="La mejor forma de entender el recorrido es caminarlo: coordiná una entrevista."
  />
</BaseLayout>
