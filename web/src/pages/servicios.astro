---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import PageHero from "../components/PageHero.astro";
import { PORTALS } from "../data/site";

import casonaFrente from "../assets/img/casona-frente.jpg";
---

<BaseLayout
  title="Servicios · Portales y herramientas para familias | Colegio Esquiú"
  description="Accesos directos a las plataformas del Colegio Esquiú: Handing para inicial y primaria, Acadeu para secundaria, intranet administrativa y manual de uniformes."
  headerTone="dark"
>
  <PageHero
    overline="Servicios"
    title="Todo lo que usás, en un solo lugar"
    lead="Los accesos a las plataformas de comunicación y gestión del colegio, siempre a mano."
    image={casonaFrente}
    imageAlt="La casona del colegio vista de frente desde el patio"
    imagePosition="center 55%"
  />

  <section class="section-y" aria-label="Portales del colegio">
    <div class="container-site">
      <div class="grid gap-5 sm:grid-cols-2" data-reveal-group>
        {
          PORTALS.map((portal) => (
            <a
              href={portal.href}
              target="_blank"
              rel="noreferrer"
              class="card group hover:shadow-float flex items-start justify-between gap-6 p-7 transition-all duration-300 hover:-translate-y-1 sm:p-8"
              data-reveal
            >
              <div>
                <h2 class="text-title-sm">{portal.name}</h2>
                <p class="text-ink-soft mt-2 text-[0.92rem] leading-relaxed">
                  {portal.description}
                </p>
              </div>
              <span
                class="border-line text-ink-soft group-hover:border-paper group-hover:bg-paper group-hover:text-ink flex h-11 w-11 shrink-0 items-center justify-center rounded-full border transition-colors duration-300"
                aria-hidden="true"
              >
                <Icon name="arrow-up-right" size={18} />
              </span>
            </a>
          ))
        }
      </div>

      <p class="text-ink-soft mt-10 max-w-2xl text-[0.9rem]" data-reveal>
        ¿Problemas para acceder a alguna plataforma? Escribinos a
        <a
          href="mailto:institucionales@colegioesquiu.edu.ar"
          class="link-accent text-ink font-medium">institucionales@colegioesquiu.edu.ar</a
        > y te ayudamos.
      </p>
    </div>
  </section>
</BaseLayout>
